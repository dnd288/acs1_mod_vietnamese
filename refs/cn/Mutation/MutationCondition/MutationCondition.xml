    /// <summary>统计数据的修改规则，需要跟另外一个配置值合起来用，假设值是v</summary>
    public enum g_emMutationNpcStatsValueModifier
    {
        None,
        /// <summary>不做修改，None是用来继承判断的</summary>
        Keep,
        /// <summary> 传入的值>v,1，否则0 </summary>
        GreaterOne,
        /// <summary> 传入的值除以v</summary>
        ScaleV,
        /// <summary> 传入的值除以v，并且向下取整</summary>
        ScaleV_Floor,
        /// <summary>用compareOp跟v比较，满足是1，否则是0</summary>
        Check,
    }

        /// <summary>
        /// 比较方式，仅对ValueModifyMode的Check生效
        /// </summary>
        [DefV(g_emCompareOp.Equal)]
        public g_emCompareOp CompareOp = g_emCompareOp.Equal;

        /// <summary>数据修改方式,跟<see cref="ValueModifyV"/>配合，仅对非Check生效</summary>
        [DefV(g_emMutationNpcStatsValueModifier.Keep)]
        public g_emMutationNpcStatsValueModifier ValueModifyMode;
        [DefV(1f)]
        public float ValueModifyV = float.MinValue;
        /// <summary>数据统计方式</summary>
        [DefV(g_emMutationNpcStatsMode.Add)]
        public g_emMutationNpcStatsMode StatsMode = g_emMutationNpcStatsMode.None;
        /// <summary>数据获取方式</summary>
        [DefV(g_emMutationNpcStatsGetMode.One_Total)]
        public g_emMutationNpcStatsGetMode ValueMode = g_emMutationNpcStatsGetMode.None;
        /// <summary>数据清理方式</summary>
        [DefV(g_emMutationNpcStatsClearMode.Npc)]
        public g_emMutationNpcStatsClearMode ClearMode = g_emMutationNpcStatsClearMode.None;
        /// <summary>判断通过必须旧数据小于条件，新数据大于等于条件</summary>
        [DefV(0)]
        public int CrossOnly = int.MinValue;

        /// <summary>
        /// 条件比较方式枚举
        /// </summar>
        public enum g_emCompareOp
        {
            None,
            Greater, //大于
            Less, //小于
            GreaterEqual, //大于等于
            LessEqual, //小于等于
            Equal, //等于
            NotEqual, //不等于
        }

    /// <summary>如何获取统计数据</summary>
    public enum g_emMutationNpcStatsGetMode
    {
        // 举个例子， Npc1，触发 伤害部位2 , 统计数据修改如下
        // 统计数据可能是[Npc1:[伤害部位1:2，伤害部位2:1], Npc2:[伤害部位2:3，伤害部位3:4]]
        // 那么如果是
        // 统计触发的Npc的Value是 1: Npc1.伤害部位2
        // 统计触发的Npc的Key的数量 2
        // 统计触发的Npc的Key的Value的总和 3 = 2 + 1
        // 每个Npc算一次，是2 = Npc1 + Npc2
        // 每个Key算一次，是3 =（伤害部位1，伤害部位2，伤害部位3）
        // 每个Npc的每个Key算一次，是4 (伤害部位1，伤害部位2)+(伤害部位2，伤害部位3)
        // 全量统计：10=2+1+3+4
        
        None,
        
        // 只计算触发的Npc
        /// <summary>统计触发的Npc的Value</summary>
        One_Value,
        /// <summary>统计触发的Npc的Key的数量</summary>
        One_KeyOnly,
        /// <summary>统计触发的Npc的Key的Value的总和</summary>
        One_Total,

        // 多个Npc计算
        /// <summary>每个Npc算一次</summary>
        All_NpcOnly,
        /// <summary>每个Npc的每个Key算一次</summary>
        All_KeyForNpcOnly,
        /// <summary>每个Key算一次</summary>
        All_KeyOnly,
        /// <summary>全量统计</summary>
        All_Total,
    }

    /// <summary>如何清除统计数据</summary>
    public enum g_emMutationNpcStatsClearMode
    {
        None,
        /// <summary>不清理</summary>
        Skip,
        /// <summary>仅清理Npc的触发类型数据</summary>
        Key,
        /// <summary>仅清理触发的Npc数据</summary>
        Npc,
        /// <summary>所有数据，清零</summary>
        Total,
    }
      
