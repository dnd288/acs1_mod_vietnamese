<Defs>
    <List>
        <Def Name="Mutation_Effect_Debug">
            <DisplayName>失落之意</DisplayName>
            <Desc>…………无事发生。</Desc>
            <NotRandom>1</NotRandom>
            <Effects></Effects>
        </Def>

        <Def Name="Mutation_Effect_ConstantBase">
            <DisplayName>恒定效果模板</DisplayName>
            <NotRandom>1</NotRandom>
            <Tag>Constant</Tag>              <!-- 效果类型标记 Constant Unstable Yin Yang-->
            <NotRemove>1</NotRemove>           <!-- 卡牌失效后，施加到门派和npc上的效果是否要移除  大于0 不移除， 默认移除-->
        </Def>

        <Def Name="Mutation_Effect_UnstableBase">
            <DisplayName>动荡效果模板</DisplayName>
            <NotRandom>1</NotRandom>
            <Level>1</Level>                       <!-- 出现在某个等级的池子中-->
            <Weight>100,-1,-1</Weight>               <!-- 浅层，中层，深层 各程度对应的权重-->
            <OneOnly>1</OneOnly>
            <WorkCount>5</WorkCount>     <!--可激活次数-->
            <Tag>Unstable</Tag>
        </Def>

        <Def Name="Mutation_Effect_YinBase">
            <DisplayName>阴效果模板</DisplayName>
            <NotRandom>1</NotRandom>
            <Level>1</Level>
            <Weight>100,100,100</Weight>
            <Tag>Yin</Tag>                             
        </Def>

        <Def Name="Mutation_Effect_YangBase">
            <DisplayName>阳效果模板</DisplayName>
            <NotRandom>1</NotRandom>
            <Level>1</Level>
            <Weight>100,100,100</Weight>
            <Tag>Yang</Tag>
        </Def>
        
    </List>
</Defs>